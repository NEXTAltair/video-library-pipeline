{
  "id": "video-library-pipeline",
  "name": "Video Library Pipeline",
  "description": "Config-driven video library pipeline for inventory, metadata extraction, move planning, apply, and audit logging.",
  "version": "0.2.0",
  "requires": {
    "plugins": ["czkawka-cli"]
  },
  "skills": [
    "./skills/video-library-pipeline",
    "./skills/inventory-review",
    "./skills/extract-review",
    "./skills/move-review",
    "./skills/relocate-review",
    "./skills/folder-cleanup"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "db": { "type": "string", "minLength": 1 },
      "sourceRoot": { "type": "string", "minLength": 1 },
      "destRoot": { "type": "string", "minLength": 1 },
      "windowsOpsRoot": { "type": "string", "minLength": 1 },
      "defaultMaxFilesPerRun": { "type": "integer", "minimum": 1, "maximum": 5000 },
      "tsRoot": { "type": "string", "minLength": 1 },
      "driveRoutesPath": { "type": "string", "minLength": 1 }
    }
  },
  "uiHints": {
    "db": { "label": "SQLite DB path", "placeholder": "<windows-ops-root>/db/mediaops.sqlite" },
    "sourceRoot": { "label": "Source root", "placeholder": "<source-root>" },
    "destRoot": { "label": "Destination root", "placeholder": "<dest-root>" },
    "windowsOpsRoot": { "label": "Windows ops root", "placeholder": "<windows-ops-root>" },
    "defaultMaxFilesPerRun": { "label": "Default batch limit" },
    "tsRoot": { "label": "TS recording root", "placeholder": "J:\\TVFile" },
    "driveRoutesPath": { "label": "Drive routes YAML", "placeholder": "rules/drive_routes.yaml" }
  }
}
